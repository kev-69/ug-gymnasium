PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5174

# Database Configuration
# For local development with Docker: postgresql://postgres:password@localhost:5432/ug_gymnasium
DATABASE_URL="postgresql://postgres:password@localhost:5432/ug-gymnasium"

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Paystack Configuration
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
# Developer subaccount for split payments (5% revenue share)
PAYSTACK_DEVELOPER_SUBACCOUNT=ACCT_xxxxxxxxxx
# Payment timeout in minutes (default: 30) - after this time, pending payments are marked as failed
PAYMENT_TIMEOUT_MINUTES=30

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# Email address to receive contact form submissions
CONTACT_EMAIL=info@gymnasium.ug.edu.gh

# Subscription Configuration
# Number of days before expiration to send warning email (default: 3)
EXPIRATION_WARNING_DAYS=3